# ── 데이터베이스 (Supabase → Settings → Database) ──────────────
# Transaction pooler (6543 포트) — 앱 런타임용
DATABASE_URL="postgresql://postgres.xxxx:PASSWORD@aws-0-ap-northeast-2.pooler.supabase.com:6543/postgres?pgbouncer=true"
# Direct connection (5432 포트) — 마이그레이션용
DIRECT_URL="postgresql://postgres.xxxx:PASSWORD@aws-0-ap-northeast-2.pooler.supabase.com:5432/postgres"

# ── 인증 (필수) ──────────────────────────────────────────────
# 생성: openssl rand -base64 32  (또는 npx auth secret)
AUTH_SECRET=""
AUTH_TRUST_HOST=true

# ── 전화번호 암호화 키 (필수, 64자리 hex = 32바이트) ─────────────
# 생성: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
PHONE_ENC_KEY=""

# ── Supabase Storage (프로필 사진 업로드) ─────────────────────
# Supabase → Settings → API
SUPABASE_URL="https://xxxx.supabase.co"
SUPABASE_SERVICE_ROLE_KEY=""
SUPABASE_STORAGE_BUCKET="photos"

# ── 이메일 발송 (인증코드 6자리) ──────────────────────────────
# Gmail 사용 시: SMTP_HOST=smtp.gmail.com / SMTP_PORT=465 / SMTP_USER=본인@gmail.com / SMTP_PASS=앱비밀번호(16자리)
# 미설정 시 개발 모드: 코드가 서버 콘솔에 출력됨
SMTP_HOST=""
SMTP_PORT="465"
SMTP_USER=""
SMTP_PASS=""
MAIL_FROM="다리 <본인@gmail.com>"

# ── Vercel Cron 보호 (선택) ──────────────────────────────────
CRON_SECRET=""
